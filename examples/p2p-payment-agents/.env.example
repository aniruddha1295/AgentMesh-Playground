# Base Sepolia Testnet Configuration
# ===================================

# RPC endpoint (free public endpoint, no API key needed)
RPC_URL=https://sepolia.base.org

# Buyer wallet private key
# Generate with: python -c "from eth_account import Account; a=Account.create(); print(f'PRIVATE_KEY={a.key.hex()}\nADDRESS={a.address}')"
# Fund with test USDC: https://faucet.circle.com/ (select Base Sepolia, 20 USDC free)
BUYER_PRIVATE_KEY=0x_paste_buyer_private_key_here

# Merchant wallet private key
# Fund with test ETH for gas: https://www.coinbase.com/faucets/base-ethereum-sepolia-faucet
MERCHANT_PRIVATE_KEY=0x_paste_merchant_private_key_here
